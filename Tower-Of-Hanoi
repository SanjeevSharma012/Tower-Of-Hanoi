class Solution {
    public int towerOfHanoi(int n, int from, int to, int aux) {
        // code here
        
        if(n == 0) return 0;
        
        int moves = 0 ;
        
        moves += towerOfHanoi(n - 1,from , aux ,to);
        
    //   System.out.println(from + "->" + aux);
       moves++;
       
       moves += towerOfHanoi(n - 1, to , from ,aux);
       
       return moves;
       
    }
}
